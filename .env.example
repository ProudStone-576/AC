# Database
# Development: SQLite
DATABASE_PROVIDER="sqlite"
DATABASE_URL="file:./dev.db"

# Production: PostgreSQL
# DATABASE_PROVIDER="postgresql"
# DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/aethoncore?sslmode=require"

# Auth
# Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET="replace-with-96-char-hex-secret"

# App URL
NEXT_PUBLIC_APP_URL="https://yourdomain.com"

# Email (SMTP)
# Leave blank in development to print emails to the console instead of sending.
SMTP_HOST="smtp.resend.com"
SMTP_PORT="465"
SMTP_USER="resend"
SMTP_PASS="your-api-key-here"
EMAIL_FROM="Aethon Core <noreply@yourdomain.com>"

# Stripe
# Get keys from the Stripe dashboard.
# STRIPE_SECRET_KEY="sk_live_..."
# STRIPE_WEBHOOK_SECRET="whsec_..."
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_live_..."

# Google OAuth
# Authorized redirect URI: https://yourdomain.com/api/auth/google/callback
# GOOGLE_CLIENT_ID="your-client-id.apps.googleusercontent.com"
# GOOGLE_CLIENT_SECRET="your-client-secret"

# Microsoft OAuth / Entra ID
# Redirect URI: https://yourdomain.com/api/auth/microsoft/callback
# MICROSOFT_CLIENT_ID="00000000-0000-0000-0000-000000000000"
# MICROSOFT_CLIENT_SECRET="your-client-secret-value"

# Apple Sign In
# Return URL: https://yourdomain.com/api/auth/apple/callback
# APPLE_CLIENT_ID="com.yourcompany.web"
# APPLE_TEAM_ID="XXXXXXXXXX"
# APPLE_KEY_ID="XXXXXXXXXX"
# APPLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"

# Anthropic AI (portal assistant)
# ANTHROPIC_API_KEY="sk-ant-..."

# Analytics (Plausible)
# Set to your production domain to enable privacy-first analytics.
# PLAUSIBLE_DOMAIN="aethoncore.com"

# Google Search Console
# GOOGLE_SITE_VERIFICATION="your-token-here"

# Error monitoring
# ERROR_WEBHOOK_URL="https://monitoring.example.com/hooks/errors"
